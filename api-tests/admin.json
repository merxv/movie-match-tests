{
  "info": {
    "_postman_id": "1f2207f7-5ff6-4fb8-8d22-d6e60b2c66c8",
    "name": "S04 Admin CRUD",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "TC05 create movie, TC09 update movie, TC10 delete movie, TC12 invalid token."
  },
  "item": [
    {
      "name": "TC05 Login as admin",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/users/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "users",
            "login"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Admin login returned 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const body = pm.response.json();",
              "pm.expect(body.token).to.be.a('string').and.not.empty;",
              "pm.environment.set('adminToken', body.token);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "TC05 Create movie",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const timestamp = Date.now();",
              "pm.environment.set('adminMovieTitle', `Postman Admin Movie ${timestamp}`);",
              "pm.environment.set('adminMovieYear', '2026');",
              "pm.environment.set('adminMovieDescription', `Created by Postman/Newman at ${timestamp}`);"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Create movie returned 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "",
              "const body = pm.response.json();",
              "pm.expect(body._id).to.be.a('string').and.not.empty;",
              "pm.expect(body.title).to.eql(pm.environment.get('adminMovieTitle'));",
              "pm.environment.set('createdMovieId', body._id);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"{{adminMovieTitle}}\",\n  \"year\": {{adminMovieYear}},\n  \"description\": \"{{adminMovieDescription}}\",\n  \"genre\": [\"Sci-Fi\", \"Drama\"],\n  \"tags\": [\"postman-admin\", \"qa-sync\", \"automation\"]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/movies",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "movies"
          ]
        }
      }
    },
    {
      "name": "TC09 Update movie",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const timestamp = Date.now();",
              "pm.environment.set('updatedMovieTitle', `Postman Updated Movie ${timestamp}`);",
              "pm.environment.set('updatedMovieDescription', `Updated by Postman/Newman at ${timestamp}`);"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Update movie returned 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const body = pm.response.json();",
              "pm.expect(body.message).to.eql('Movie updated successfully');",
              "pm.expect(body.movie._id).to.eql(pm.environment.get('createdMovieId'));",
              "pm.expect(body.movie.title).to.eql(pm.environment.get('updatedMovieTitle'));"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"{{updatedMovieTitle}}\",\n  \"year\": 2027,\n  \"description\": \"{{updatedMovieDescription}}\",\n  \"tags\": [\"postman-admin\", \"updated\", \"automation\"]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/movies/{{createdMovieId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "movies",
            "{{createdMovieId}}"
          ]
        }
      }
    },
    {
      "name": "TC09 Verify updated movie in catalog",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/movies",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "movies"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Movies after update returned 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const movies = pm.response.json();",
              "const movie = movies.find((entry) => entry._id === pm.environment.get('createdMovieId'));",
              "pm.expect(movie, 'Updated movie should exist in catalog').to.exist;",
              "pm.expect(movie.title).to.eql(pm.environment.get('updatedMovieTitle'));"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "TC10 Delete movie",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/movies/{{createdMovieId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "movies",
            "{{createdMovieId}}"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Delete movie returned 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const body = pm.response.json();",
              "pm.expect(body.deletedId).to.eql(pm.environment.get('createdMovieId'));"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "TC10 Verify movie removed from catalog",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/movies",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "movies"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Movies after delete returned 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const movies = pm.response.json();",
              "const movie = movies.find((entry) => entry._id === pm.environment.get('createdMovieId'));",
              "pm.expect(movie, 'Deleted movie should be absent from catalog').to.not.exist;"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "TC12 Invalid token is denied",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer invalid-admin-token"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Should Not Be Created\",\n  \"year\": 2026,\n  \"description\": \"Negative test for invalid token\",\n  \"genre\": [\"Test\"],\n  \"tags\": [\"invalid-token\"]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/movies",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "movies"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Invalid token request returned 401', function () {",
              "  pm.response.to.have.status(401);",
              "});",
              "",
              "const body = pm.response.json();",
              "pm.expect(body.error).to.eql('Invalid token.');"
            ],
            "type": "text/javascript"
          }
        }
      ]
    }
  ]
}
